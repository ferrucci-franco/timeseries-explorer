# Ignore everything by default.
*

# Standard generated folders
/node_modules/
/dist/
/portable-dist/
/desktop-dist/

# Keep local/archive material out of sync.
/old/
/backup/
/.codex/
/.claude/
/python/

# Track project source and metadata.
!/.gitignore
!/*.js
!/*.html
!/*.css
!/*.bat
!/package.json
!/package-lock.json
!/README.md
!/CONTRIBUTING.md
!/.codex/
!/.codex/TODO.txt
!/src/
!/src/**
!/public/
!/public/**
!/docs/
!/docs/**
!/scripts/
!/scripts/**
!/electron/
!/electron/**
!/build/
!/build/icons/
!/build/icons/**
!/test-files/
!/test-files/csv/
!/test-files/csv/date-parsing-options/
!/test-files/csv/date-parsing-options/**
!/test-files/live_update/
!/test-files/live_update/*.py
!/test-files/pypsa/
!/test-files/pypsa/*.nc
!/bench/
!/bench/**

# Perf benchmark synthetic data (large, regenerable).
/bench/data/
/bench/**/*.csv

# Generated download artifacts stay local.
/public/downloads/*.zip
/public/downloads/standalone.json
