# Ignore everything by default.
*

# Standard generated folders
/node_modules/
/dist/
/portable-dist/

# Keep local/archive material out of sync.
/old/
/backup/
/.codex/
/.claude/
/python/

# Track project source and metadata.
!/.gitignore
!/*.js
!/*.html
!/*.css
!/*.bat
!/package.json
!/package-lock.json
!/README.md
!/CONTRIBUTING.md
!/src/
!/src/**
!/public/
!/public/**
!/docs/
!/docs/**
!/scripts/
!/scripts/**

# Generated download artifacts stay local.
/public/downloads/*.zip
/public/downloads/standalone.json
