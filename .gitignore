# Ignore everything by default.
*

# Standard generated folders
/node_modules/
/dist/
/portable-dist/
/desktop-dist/

# Keep local/archive material out of sync.
/old/
/backup/
/.codex/
/.claude/
/python/

# Track project source and metadata.
!/.gitignore
!/.github/
!/.github/**
!/*.js
!/*.html
!/*.css
!/*.bat
!/package.json
!/package-lock.json
!/README.md
!/CONTRIBUTING.md
!/LICENSE
!/PUBLICATION.md
!/CITATION.cff
!/THIRD_PARTY_LICENSES.md
!/.codex/
!/.codex/TODO.txt
!/src/
!/src/**
!/public/
!/public/**
!/docs/
!/docs/**
!/scripts/
!/scripts/**
# Personal Spyder worksheets.
/scripts/gen-multiindex-parquet-spyder.py
/scripts/__pycache__/
!/electron/
!/electron/**
!/build/
!/build/icons/
!/build/icons/**
!/test-files/
!/test-files/csv/
!/test-files/csv/**
# Generated locally by scripts/gen-*-large-csv.py (large, regenerable).
/test-files/csv/correlation-large.csv
/test-files/csv/missing-large.csv
!/test-files/excel/
!/test-files/excel/**
!/test-files/parquet/
!/test-files/parquet/**
!/test-files/live_update/
!/test-files/live_update/*.py
!/test-files/pypsa/
!/test-files/pypsa/vetea_example_01.nc
!/test-files/pickle/
!/test-files/pickle/*.pkl
!/test-files/pickle/manifest.json
!/test-files/matlab/
!/test-files/matlab/*.mat
!/bench/
!/bench/**

# Perf benchmark synthetic data (large, regenerable).
/bench/data/
/bench/**/*.csv

# Generated download artifacts stay local.
/public/downloads/*.zip
/public/downloads/standalone.json
