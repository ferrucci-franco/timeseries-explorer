{
  "name": "timeseries-explorer",
  "private": true,
  "version": "0.1.0-beta.10",
  "description": "Desktop and web time-series explorer for MATLAB, Modelica, tabular, and netCDF data.",
  "author": "Franco Ferrucci",
  "license": "MIT",
  "homepage": "https://ferrucci-franco.github.io/timeseries-explorer/",
  "repository": {
    "type": "git",
    "url": "https://github.com/ferrucci-franco/timeseries-explorer.git"
  },
  "bugs": {
    "url": "https://github.com/ferrucci-franco/timeseries-explorer/issues"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "serve:local": "node scripts/portable-server.mjs",
    "desktop": "npm run build:web && node scripts/start-electron.mjs",
    "desktop:pack": "npm run build:web && node scripts/run-electron-builder.mjs --dir",
    "desktop:dist": "npm run desktop:dist:windows:x64",
    "desktop:dist:windows:x64": "npm run build:web && node scripts/run-electron-builder.mjs --win nsis portable --x64",
    "desktop:dist:x64": "npm run desktop:dist:windows:x64",
    "desktop:dist:macos:x64": "npm run build:web && node scripts/run-electron-builder.mjs --mac dmg zip --x64",
    "desktop:dist:macos:arm64": "npm run build:web && node scripts/run-electron-builder.mjs --mac dmg zip --arm64",
    "desktop:dist:linux:x64": "npm run build:web && node scripts/run-electron-builder.mjs --linux deb AppImage --x64",
    "desktop:checksums": "node scripts/create-desktop-checksums.mjs",
    "desktop:verify-package": "node scripts/verify-packaged-desktop.mjs",
    "desktop:icon": "node scripts/render-desktop-icon.mjs",
    "build:web": "vite build",
    "build": "npm run build:web",
    "preview": "vite preview",
    "build:portable": "node scripts/build-portable.mjs",
    "build:all": "npm run build:portable && npm run build:web",
    "test:csv": "node scripts/test-csv-fixtures.mjs",
    "test:excel": "node scripts/test-excel-parser.mjs",
    "test:matlab": "node scripts/test-matlab-parser.mjs",
    "test:capabilities": "node scripts/test-runtime-capabilities.mjs",
    "test:live-update": "node scripts/test-live-update-logic.mjs",
    "test:local-file-http": "node scripts/test-local-file-http.mjs",
    "test:loading-overlay-layout": "node scripts/test-loading-overlay-layout.mjs",
    "test:sidebar-resize": "node scripts/test-sidebar-resize.mjs",
    "test:desktop-streamable": "node scripts/test-desktop-streamable-file.mjs",
    "test:electron-navigation": "node scripts/test-electron-navigation-policy.mjs",
    "test:desktop-download": "node scripts/test-desktop-download-dialog.mjs",
    "test:desktop-release": "node scripts/test-desktop-release-config.mjs",
    "test:csv-to-parquet": "node scripts/test-csv-to-parquet-core.mjs",
    "test:parquet-pandas": "node scripts/test-parquet-pandas-metadata.mjs",
    "test:parquet-loading": "node scripts/test-parquet-loading-mode.mjs",
    "test:data-tools": "node scripts/test-data-tools.mjs",
    "test:variable-sign": "node scripts/test-variable-sign-toggle.mjs",
    "test:file-transform": "node scripts/test-file-transform-reset.mjs",
    "test:csv-export": "node scripts/test-csv-export-time-columns.mjs",
    "test:csv-elapsed": "node scripts/test-csv-elapsed-format.mjs",
    "test:cursor-y2": "node scripts/test-cursor-y2.mjs",
    "test:autoscale-axis": "node scripts/test-autoscale-axis.mjs",
    "test:i18n-consistency": "node scripts/test-i18n-consistency.mjs",
    "test:time-axis-model": "node scripts/test-time-axis-model.mjs",
    "test:operation-capabilities": "node scripts/test-operation-capabilities.mjs",
    "test:time-axis-readers": "node scripts/test-time-axis-readers.mjs",
    "test:panel-time-axis": "node scripts/test-panel-time-axis.mjs",
    "test:calendar-axis": "node scripts/test-calendar-axis.mjs",
    "test:calendar-heatmap": "node scripts/test-calendar-heatmap.mjs",
    "test:fft": "node scripts/test-fft.mjs",
    "test:histogram": "node scripts/test-histogram.mjs",
    "test:temporal-profile": "node scripts/test-temporal-profile.mjs",
    "test:temporal-profile-lazy": "node scripts/test-temporal-profile-lazy.mjs",
    "test:mode-toolbar": "node scripts/test-mode-toolbar.mjs",
    "test:timeseries-stack": "node scripts/test-timeseries-stack.mjs",
    "test:timeseries-y-expand": "node scripts/test-timeseries-y-expand.mjs",
    "test:missing-data": "node scripts/test-missing-data.mjs",
    "test:missing-lazy": "node scripts/test-missing-lazy.mjs",
    "test:correlation": "node scripts/test-correlation.mjs",
    "test:correlation-lazy": "node scripts/test-correlation-lazy.mjs",
    "test:regression": "node scripts/test-regression.mjs",
    "test:regression-lazy": "node scripts/test-regression-lazy.mjs",
    "test:regression-conditioning": "node scripts/test-regression-conditioning.mjs",
    "test:lazy-phase": "node scripts/test-lazy-phase-logic.mjs",
    "test:pickle": "node scripts/test-pickle-parser.mjs",
    "test:netcdf": "node scripts/test-generic-netcdf-parser.mjs",
    "verify:netcdf-corpus": "node scripts/verify-netcdf-corpus.mjs",
    "test:pypsa": "node scripts/test-pypsa-netcdf-parser.mjs",
    "test:pypsa-session": "node scripts/test-pypsa-session.mjs",
    "test:session-project": "node scripts/test-session-project-save.mjs",
    "test:session-state": "node scripts/test-session-state-roundtrip.mjs",
    "test:feedback-form": "node scripts/test-feedback-form.mjs",
    "test:help-layout": "node scripts/test-help-layout.mjs",
    "test:settings-layout": "node scripts/test-settings-layout.mjs",
    "inspect:pypsa": "node scripts/inspect-pypsa-netcdf.mjs",
    "test:phase2d": "node scripts/test-phase2d.mjs",
    "test:release": "node scripts/run-release-tests.mjs"
  },
  "devDependencies": {
    "adm-zip": "^0.5.16",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.5",
    "sharp": "^0.35.2",
    "vite": "^5.4.19"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "1.32.0",
    "duckdb": "1.4.4",
    "fflate": "^0.8.3",
    "h5wasm": "^0.10.3",
    "netcdfjs": "^4.0.0",
    "pickleparser": "^0.2.1",
    "plotly.js-dist-min": "^3.5.1",
    "plotly.js-locales": "3.5.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "overrides": {
    "tar": ">=7.5.21"
  },
  "build": {
    "appId": "io.github.ferrucci-franco.timeseries-explorer",
    "productName": "Time Series Explorer",
    "copyright": "Copyright © 2026 Franco Ferrucci",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "icon": "build/icons/timeseries-explorer-icon.png",
    "directories": {
      "output": "desktop-dist"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/data/csv-to-parquet-core.js",
      "src/parsers/**/*",
      "build/icons/**/*",
      "package.json",
      "!node_modules/node-gyp{,/**/*}",
      "!node_modules/**/node-gyp{,/**/*}",
      "!node_modules/cacache{,/**/*}",
      "!node_modules/**/cacache{,/**/*}",
      "!node_modules/make-fetch-happen{,/**/*}",
      "!node_modules/**/make-fetch-happen{,/**/*}",
      "!node_modules/tar{,/**/*}",
      "!node_modules/**/tar{,/**/*}"
    ],
    "asar": true,
    "asarUnpack": [
      "src/data/csv-to-parquet-core.js",
      "src/parsers/**/*",
      "**/*.node"
    ],
    "win": {
      "icon": "build/icons/timeseries-explorer-icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-setup-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "category": "Utility",
      "synopsis": "Explore time-series data",
      "description": "Offline desktop application for exploring time-series data.",
      "maintainer": "Franco Ferrucci"
    },
    "deb": {
      "packageCategory": "utils",
      "priority": "optional"
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "npmRebuild": false
  }
}
